# 빌드 산출물 (모든 모듈)
# 예전에는 /build 와 /app/build 만 막아둬서 core/*, testapp/* 의 빌드 결과가
# 저장소에 그대로 커밋되고 있었다.
build/

/.gradle
/local.properties
/.idea
.DS_Store
/*.iml
/captures
/app/.cxx
/app/.externalNativeBuild
/app/libs

# Gradle Wrapper
!gradle-wrapper.jar

# Android Studio
.idea/
.gradle/
local.properties
*.iml
*.ipr
*.iws
.vscode/

# Logs
*.log

# Crashlytics
*.zip

# Keystore files
*.jks

# Documentation
docs/*.bak
